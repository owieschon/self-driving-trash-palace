{
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "items": {
            "$ref": "#/$defs/__schema0"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "authority": {
      "const": "runtime_state_only",
      "type": "string"
    },
    "expiresAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "instructionRole": {
      "const": "untrusted_evidence",
      "type": "string"
    },
    "observedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "requiredPermission": {
      "enum": [
        "palace:read",
        "crew:read",
        "capability:read",
        "routine:read",
        "routine:draft",
        "routine:validate",
        "routine:simulate",
        "routine:approve",
        "routine:activate",
        "recovery:propose",
        "operation:reconcile",
        "verification:read",
        "knowledge:read",
        "mission:cancel"
      ],
      "type": "string"
    },
    "snapshotHash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "snapshotId": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "type": "string"
    },
    "source": {
      "const": "host-runtime",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/__schema0"
    },
    "stateHash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "stateKind": {
      "enum": [
        "palace",
        "crew",
        "capabilities",
        "routines",
        "executions",
        "mission",
        "plan",
        "operation",
        "verification_evidence"
      ],
      "type": "string"
    },
    "tenantScopeHash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    }
  },
  "required": [
    "source",
    "authority",
    "instructionRole",
    "snapshotId",
    "stateKind",
    "requiredPermission",
    "tenantScopeHash",
    "observedAt",
    "state",
    "stateHash",
    "snapshotHash"
  ],
  "type": "object"
}
