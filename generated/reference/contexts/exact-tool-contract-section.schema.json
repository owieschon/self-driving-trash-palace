            "additionalProperties": false,
            "properties": {
              "authentication": {
                "const": "session_or_bearer",
                "type": "string"
              },
              "method": {
                "const": "POST",
                "type": "string"
              },
              "path": {
                "pattern": "^\\/api\\/v1\\/tools\\/[a-z][a-z_.]+$",
                "type": "string"
              }
            },
            "required": [
              "method",
              "path",
              "authentication"
