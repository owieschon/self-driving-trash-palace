                  },
                  "readOnlyHint": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "readOnlyHint",
                  "destructiveHint",
                  "idempotentHint",
                  "openWorldHint"
                ],
                "type": "object"
              },
              "description": {
                "maxLength": 500,
                "minLength": 1,
                "type": "string"
              },
              "title": {
                "maxLength": 120,
                "minLength": 1,
                "type": "string"
              }
            },
