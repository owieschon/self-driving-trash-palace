      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "contractId": {
      "const": "caretaker-tool-and-error-contracts",
      "type": "string"
    },
    "contractVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "instructionRole": {
