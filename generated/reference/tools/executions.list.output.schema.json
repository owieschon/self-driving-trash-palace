                    "name",
                    "commandId",
                    "status",
                    "evidenceId",
                    "resolvedAt",
                    "failure"
                  ],
                  "type": "object"
                },
                {
                  "additionalProperties": false,
                  "properties": {
                    "commandId": {
                      "anyOf": [
                        {
                          "pattern": "^gcmd_[a-z0-9][a-z0-9_-]{7,63}$",
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
