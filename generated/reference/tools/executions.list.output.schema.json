                      "type": "string"
                    },
                    "failure": {
                      "type": "null"
                    },
                    "name": {
                      "enum": [
                        "preheat",
                        "verified_arrival",
                        "pathway_lighting",
                        "unlock",
                        "relock",
                        "access_window",
                        "verified_hauler_identity",
                        "service_hatch_unlock",
                        "service_hatch_relock",
                        "residential_hatch_guard"
                      ],
                      "type": "string"
                    },
                    "resolvedAt": {
                      "format": "date-time",
