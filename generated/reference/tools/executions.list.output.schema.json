                    },
                    "resolvedAt": {
                      "type": "null"
                    },
                    "status": {
                      "const": "pending",
                      "type": "string"
                    }
                  },
                  "required": [
                    "name",
                    "commandId",
                    "status",
                    "evidenceId",
                    "resolvedAt",
                    "failure"
                  ],
                  "type": "object"
                },
                {
