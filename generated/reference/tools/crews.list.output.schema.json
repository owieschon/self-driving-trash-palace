{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "crew": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "active": {
            "type": "boolean"
          },
          "displayName": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "id": {
            "pattern": "^crew_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "organizationId": {
            "pattern": "^org_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "palaceId": {
            "pattern": "^pal_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "userId": {
            "anyOf": [
              {
                "pattern": "^usr_[a-z0-9][a-z0-9_-]{7,63}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "id",
          "organizationId",
          "palaceId",
          "userId",
          "displayName",
          "active"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "identityTags": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "active": {
            "type": "boolean"
          },
          "crewMemberId": {
            "anyOf": [
              {
                "pattern": "^crew_[a-z0-9][a-z0-9_-]{7,63}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "id": {
            "pattern": "^tag_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "label": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "organizationId": {
            "pattern": "^org_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "verified": {
            "type": "boolean"
          },
          "version": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          }
        },
        "required": [
          "id",
          "organizationId",
          "crewMemberId",
          "label",
          "verified",
          "active",
          "version"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "preferences": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "active": {
            "type": "boolean"
          },
          "crewMemberId": {
            "pattern": "^crew_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "id": {
            "pattern": "^pref_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "kind": {
            "const": "homecoming_comfort",
            "type": "string"
          },
          "organizationId": {
            "pattern": "^org_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "palaceId": {
            "pattern": "^pal_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "pathwayLightingDurationSeconds": {
            "maximum": 86400,
            "minimum": 1,
            "type": "integer"
          },
          "pathwayLightingIntensityPercent": {
            "maximum": 100,
            "minimum": 0,
            "type": "integer"
          },
          "targetCelsius": {
            "maximum": 35,
            "minimum": 5,
            "type": "number"
          },
          "version": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          }
        },
        "required": [
          "id",
          "organizationId",
          "palaceId",
          "crewMemberId",
          "kind",
          "active",
          "version",
          "targetCelsius",
          "pathwayLightingIntensityPercent",
          "pathwayLightingDurationSeconds"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schedules": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "active": {
            "type": "boolean"
          },
          "crewMemberId": {
            "pattern": "^crew_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "id": {
            "pattern": "^sch_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "organizationId": {
            "pattern": "^org_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "palaceId": {
            "pattern": "^pal_[a-z0-9][a-z0-9_-]{7,63}$",
            "type": "string"
          },
          "timezone": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "windowEnd": {
            "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$",
            "type": "string"
          },
          "windowStart": {
            "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$",
            "type": "string"
          }
        },
        "required": [
          "id",
          "organizationId",
          "palaceId",
          "crewMemberId",
          "active",
          "version",
          "timezone",
          "windowStart",
          "windowEnd"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "crew",
    "identityTags",
    "schedules",
    "preferences"
  ],
  "type": "object"
}
