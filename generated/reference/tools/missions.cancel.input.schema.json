{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "missionId": {
      "pattern": "^mis_[a-z0-9][a-z0-9_-]{7,63}$",
      "type": "string"
    },
    "reason": {
      "maxLength": 500,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "missionId",
    "reason"
  ],
  "type": "object"
}
