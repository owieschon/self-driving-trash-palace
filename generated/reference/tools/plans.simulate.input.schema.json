{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "planId": {
      "pattern": "^pln_[a-z0-9][a-z0-9_-]{7,63}$",
      "type": "string"
    },
    "scenarios": {
      "default": [
        "timing",
        "access",
        "energy",
        "transport_failure"
      ],
      "items": {
        "enum": [
          "timing",
          "access",
          "energy",
          "transport_failure"
        ],
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "planId",
    "scenarios"
  ],
  "type": "object"
}
