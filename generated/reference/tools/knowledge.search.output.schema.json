        "properties": {
          "excerpt": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          },
          "sourceId": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "title": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "version": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          }
