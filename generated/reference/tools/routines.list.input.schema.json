{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "palaceId": {
      "pattern": "^pal_[a-z0-9][a-z0-9_-]{7,63}$",
      "type": "string"
    },
    "statuses": {
      "items": {
        "enum": [
          "draft",
          "active",
          "inactive",
          "archived"
        ],
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "palaceId"
  ],
  "type": "object"
}
