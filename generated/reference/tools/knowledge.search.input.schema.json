{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "limit": {
      "default": 6,
      "maximum": 12,
      "minimum": 1,
      "type": "integer"
    },
    "phase": {
      "enum": [
        "understand",
        "plan",
        "validate",
        "approve",
        "execute",
        "reconcile",
        "observe",
        "verify"
      ],
      "type": "string"
    },
    "query": {
      "maxLength": 500,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "query",
    "phase",
    "limit"
  ],
  "type": "object"
}
