{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "activeOnly": {
      "default": true,
      "type": "boolean"
    },
    "palaceId": {
      "pattern": "^pal_[a-z0-9][a-z0-9_-]{7,63}$",
      "type": "string"
    }
  },
  "required": [
    "palaceId",
    "activeOnly"
  ],
  "type": "object"
}
