{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "palace": {
      "additionalProperties": false,
      "properties": {
        "batteryAvailablePercentage": {
          "maximum": 100,
          "minimum": 0,
          "type": "number"
        },
        "createdAt": {
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
          "type": "string"
        },
        "id": {
          "pattern": "^pal_[a-z0-9][a-z0-9_-]{7,63}$",
          "type": "string"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "type": "string"
        },
        "organizationId": {
          "pattern": "^org_[a-z0-9][a-z0-9_-]{7,63}$",
          "type": "string"
        },
        "timezone": {
          "maxLength": 64,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "organizationId",
        "name",
        "timezone",
        "batteryAvailablePercentage",
        "createdAt"
      ],
      "type": "object"
    }
  },
  "required": [
    "palace"
  ],
  "type": "object"
}
