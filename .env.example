# `pnpm local:up` generates real local-only secrets in
# artifacts/private/local-stack.env. This file documents values and optional host-port overrides;
# the placeholders below are not valid runtime credentials.
TRASH_PALACE_WEB_PORT=3300
TRASH_PALACE_GATEWAY_PORT=4319
TRASH_PALACE_WORKER_HEALTH_PORT=4320
TRASH_PALACE_POSTGRES_PORT=55432

TRASH_PALACE_POSTGRES_PASSWORD=replace-with-a-random-database-password
SESSION_SIGNING_KEY=replace-with-a-random-32-byte-value
TOOL_INVOCATION_SCOPE_KEY=replace-with-an-independent-random-32-byte-value
GATEWAY_CALLBACK_SIGNING_KEY=replace-with-a-different-random-32-byte-value
IDENTITY_TELEMETRY_SIGNING_KEY=replace-with-another-independent-random-32-byte-value
TRASH_PALACE_EVIDENCE_ALIAS_KEY=replace-with-an-independent-random-32-byte-value

# Every fixture process receives this exact shared wall-clock anchor. `local:up` refreshes it only
# after the image build finishes so cold builds cannot skip scheduled events.
TRASH_PALACE_CLOCK_MODE=fixture
TRASH_PALACE_FIXTURE_REAL_START_AT=2026-08-14T05:44:00.000Z

# The composed Quest enables this lab-only application transport negative control in the worker.
# Production and hosted-demo configurations reject it even if these values are copied there.
TRASH_PALACE_LAB_MODE=true
TRASH_PALACE_APPLICATION_TRANSPORT_FAULT=application_commit_then_response_lost
TRASH_PALACE_APPLICATION_TRANSPORT_FAULT_ORGANIZATION_ID=org_rocky_roost

# Canonical local tenant and sender identities are stable fixture data, not secrets.
GATEWAY_CALLBACK_SIGNING_KEY_ID=gwk_local_gateway_2026
IDENTITY_TELEMETRY_SIGNING_KEY_ID=itk_local_identity
IDENTITY_TELEMETRY_PRINCIPAL_ID=itp_local_identity
TRASH_PALACE_LOCAL_ORGANIZATION_ID=org_rocky_roost
TRASH_PALACE_LOCAL_PALACE_ID=pal_sacred_dumpster
TRASH_PALACE_DEV_ORGANIZATION_ID=org_rocky_roost
TRASH_PALACE_DEV_USER_ID=usr_rocky_founder
TRASH_PALACE_DEV_MEMBERSHIP_ID=mem_rocky_owner

# PostHog export stays off in the credential-free local stack. A separately approved process must
# receive its project token and region; do not put either value in this file.
TRASH_PALACE_POSTHOG_EXPORT_ENABLED=false
# Caretaker stays deterministic unless an explicitly authorized live evaluation selects Claude.
TRASH_PALACE_CARETAKER_PROVIDER=deterministic
# ANTHROPIC_API_KEY=
# TRASH_PALACE_LIVE_MODEL_AUTHORIZATION_ID=
# TRASH_PALACE_CLAUDE_MAX_COST_USD_PER_DECISION=0.10
