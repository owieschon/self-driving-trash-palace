# Request-time web configuration. Use the root `pnpm local:up` command for the complete fixture;
# it generates independent secrets and the shared future clock anchor.
NODE_ENV=development
DATABASE_URL=postgresql://trash_palace:replace-with-a-password@127.0.0.1:55432/trash_palace
SESSION_SIGNING_KEY=replace-with-at-least-32-random-bytes
TOOL_INVOCATION_SCOPE_KEY=replace-with-a-different-32-byte-key
GATEWAY_CALLBACK_SIGNING_KEY=replace-with-an-independent-32-byte-key
GATEWAY_CALLBACK_SIGNING_KEY_ID=gwk_local_gateway_2026
IDENTITY_TELEMETRY_SIGNING_KEY=replace-with-another-independent-32-byte-key
IDENTITY_TELEMETRY_SIGNING_KEY_ID=itk_local_identity
IDENTITY_TELEMETRY_PRINCIPAL_ID=itp_local_identity
# Web and worker mount the same evidence directory and use the same alias-key generation. The
# interprocess-locked JSONL sink deduplicates their durable event identities.
TRASH_PALACE_EVIDENCE_ALIAS_KEY=replace-with-an-independent-random-32-byte-value
TRASH_PALACE_EVIDENCE_SINK_PATH=/var/lib/trash-palace/evidence/caretaker.jsonl
TRASH_PALACE_APP_VERSION=0.0.0
TRASH_PALACE_ENVIRONMENT=local
TRASH_PALACE_EVIDENCE_ORIGIN=fixture
TRASH_PALACE_LOCAL_ORGANIZATION_ID=org_rocky_roost
TRASH_PALACE_LOCAL_PALACE_ID=pal_sacred_dumpster
TRASH_PALACE_CLOCK_MODE=fixture
TRASH_PALACE_FIXTURE_REAL_START_AT=2026-08-14T05:44:00.000Z
TRASH_PALACE_ALLOWED_ORIGIN=http://127.0.0.1:3300

# Seeded login is denied unless development mode, loopback origin, explicit opt-in, and the exact
# canonical owner membership all agree.
TRASH_PALACE_DEV_SESSION_ENABLED=true
TRASH_PALACE_DEV_ORGANIZATION_ID=org_rocky_roost
TRASH_PALACE_DEV_USER_ID=usr_rocky_founder
TRASH_PALACE_DEV_MEMBERSHIP_ID=mem_rocky_owner
