# The executable worker uses production PostgreSQL, pg-boss, gateway, context, and evidence
# adapters. Use the root `pnpm local:up` command to migrate and seed before starting this process.
DATABASE_URL=postgresql://trash_palace:replace-with-a-password@127.0.0.1:55432/trash_palace
TRASH_PALACE_WORKER_ID=caretaker-local-1
TRASH_PALACE_WORKER_SERVICE_ACTOR_ID=usr_caretaker_service
TOOL_INVOCATION_SCOPE_KEY=replace-with-an-independent-random-32-byte-value
TRASH_PALACE_EVIDENCE_ALIAS_KEY=replace-with-an-independent-random-32-byte-value
# Web mounts this same evidence directory and writes through the same interprocess-locked sink.
TRASH_PALACE_EVIDENCE_SINK_PATH=/var/lib/trash-palace/evidence/caretaker.jsonl
TRASH_PALACE_REPOSITORY_ROOT=/workspace
TRASH_PALACE_APP_VERSION=0.0.0
TRASH_PALACE_ENVIRONMENT=local
TRASH_PALACE_EVIDENCE_ORIGIN=fixture
TRASH_PALACE_CLOCK_MODE=fixture
TRASH_PALACE_FIXTURE_REAL_START_AT=2026-08-14T05:44:00.000Z
# Lab-only deterministic negative control. Omit all three values outside local/evaluation fixtures.
TRASH_PALACE_LAB_MODE=true
TRASH_PALACE_APPLICATION_TRANSPORT_FAULT=application_commit_then_response_lost
TRASH_PALACE_APPLICATION_TRANSPORT_FAULT_ORGANIZATION_ID=org_rocky_roost
TRASH_PALACE_GATEWAY_TIMEOUT_MS=10000
TRASH_PALACE_MISSION_LEASE_TTL_MS=30000
TRASH_PALACE_OUTBOX_PUMP_INTERVAL_MS=25
TRASH_PALACE_WORKER_HEALTH_HOST=0.0.0.0
TRASH_PALACE_WORKER_HEALTH_PORT=4320
# Caretaker stays deterministic unless an explicitly authorized live evaluation selects Claude.
TRASH_PALACE_CARETAKER_PROVIDER=deterministic
# ANTHROPIC_API_KEY=
# TRASH_PALACE_LIVE_MODEL_AUTHORIZATION_ID=
# TRASH_PALACE_CLAUDE_MAX_COST_USD_PER_DECISION=0.10
