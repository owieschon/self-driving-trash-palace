# The gateway accepts only the fixed internal command origin and delivers callbacks and identity
# telemetry to the fixed internal web origin. Compose provides those service names.
GATEWAY_SIMULATOR_HOST=0.0.0.0
GATEWAY_SIMULATOR_PORT=4319
GATEWAY_SIMULATOR_LAB_MODE=false
GATEWAY_SIMULATOR_FAULT_PROFILE=none
GATEWAY_CALLBACK_SIGNING_KEY_ID=gwk_local_gateway_2026
GATEWAY_CALLBACK_SIGNING_KEY=replace-with-an-independent-random-32-byte-value
GATEWAY_CALLBACK_MAX_ATTEMPTS=4
GATEWAY_CALLBACK_INITIAL_BACKOFF_MS=100
GATEWAY_CALLBACK_MAX_BACKOFF_MS=2000
GATEWAY_CALLBACK_REQUEST_TIMEOUT_MS=2000
GATEWAY_CALLBACK_READINESS_INTERVAL_MS=1000
GATEWAY_CALLBACK_MAX_TRACKED=512
IDENTITY_TELEMETRY_SIGNING_KEY_ID=itk_local_identity
IDENTITY_TELEMETRY_SIGNING_KEY=replace-with-a-different-random-32-byte-value
IDENTITY_TELEMETRY_MAX_ATTEMPTS=4
IDENTITY_TELEMETRY_INITIAL_BACKOFF_MS=100
IDENTITY_TELEMETRY_MAX_BACKOFF_MS=2000
IDENTITY_TELEMETRY_REQUEST_TIMEOUT_MS=2000
IDENTITY_TELEMETRY_READINESS_INTERVAL_MS=1000
IDENTITY_TELEMETRY_MAX_TRACKED=128
TRASH_PALACE_FIXTURE_REAL_START_AT=2026-08-14T05:44:00.000Z
GATEWAY_SHUTDOWN_TIMEOUT_MS=10000
